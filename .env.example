# MongoDB Atlas connection string
# Get the full URI from Atlas: Database -> Connect -> Drivers
# Replace YOUR_CLUSTER with your cluster hostname (e.g. cluster0.xxxxx.mongodb.net)
MONGODB_URI=mongodb+srv://dbuser:<db_password>@cluster0.qbcdyfl.mongodb.net/?appName=Cluster0

# Local API server port (used by npm run dev:api)
API_PORT=3001
